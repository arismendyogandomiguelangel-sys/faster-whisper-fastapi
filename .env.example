# Modelo Whisper: tiny, base, small, medium, large
MODEL_SIZE=small

# Puerto del servicio
PORT=8080

# API Key para proteger /transcribe (genera una aleatoria)
API_KEY=change_me

# Device: cpu o cuda
DEVICE=cpu

# Tipo de computo: int8, float16, float32
COMPUTE_TYPE=int8

# Opcional: desactivar docs en produccion
DISABLE_DOCS=false