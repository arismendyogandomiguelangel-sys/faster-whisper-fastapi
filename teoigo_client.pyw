"""\nTEOIGO \u2014 Cliente de Dictado por Voz para Windows\n=================================================\nHerramienta del ecosistema ALiaNeD.\n\nUso:\n  1. Doble clic en este archivo (o ejecuta: pythonw teoigo_client.pyw)\n  2. El programa se queda en segundo plano\n  3. En CUALQUIER aplicacion (Word, VS Code, Chrome, etc.):\n     - Presiona  Ctrl + Flecha Derecha  para INICIAR grabacion\n     - Presiona  Ctrl + Flecha Derecha  otra vez para DETENER y transcribir\n  4. El texto transcrito se pega automaticamente donde esta tu cursor\n  5. Para salir: presiona  Ctrl + Shift + F12\n\nRequisitos:\n  pip install -r client_requirements.txt\n\nConfiguracion:\n  Edita las variables WHISPER_URL y API_KEY abajo, o configura variables de entorno.\n"""\n\nimport io\nimport os\nimport sys\nimport time\nimport wave\nimport threading\nimport ctypes\nfrom ctypes import wintypes\n\nimport keyboard\nimport sounddevice as sd\nimport numpy as np\nimport requests\nimport pyperclip\nimport pyautogui\n\n# ============================================================================\n# CONFIGURACION \u2014 Edita estos valores o usa variables de entorno\n# ============================================================================\nWHISPER_URL = os.getenv(\n    \"TEOIGO_URL\",\n    \"https://teoigo.alianed.com/v2/transcribe\"\n)\nAPI_KEY = os.getenv(\n    \"TEOIGO_API_KEY\",\n    \"CHANGE_ME_PUT_YOUR_API_KEY_HERE\"\n)\n\n# Frecuencia de muestreo del microfono (16kHz es optimo para Whisper)\nSAMPLE_RATE = 16000\n# Numero de canales (1 = mono, lo que Whisper espera)\nCHANNELS = 1\n\n# ============================================================================\n# NOTIFICACIONES TOAST DE WINDOWS (sin dependencias externas)\n# ============================================================================\n\ndef show_toast(title, message, duration_ms=2000):\n    \"\"\"\n    Muestra una notificacion emergente nativa de Windows.\n    Usa la API MessageBox en un hilo separado para no bloquear.\n    \"\"\"\n    def _show():\n        ctypes.windll.user32.MessageBoxTimeoutW(\n            0,                              # hWnd\n            message,                        # lpText\n            title,                          # lpCaption\n            0x00040040,                     # MB_ICONINFORMATION | MB_SETFOREGROUND\n            0,                              # wLanguageId\n            duration_ms                     # dwMilliseconds\n        )\n    # Intentamos usar MessageBoxTimeoutW (existe en todas las versiones modernas)\n    try:\n        threading.Thread(target=_show, daemon=True).start()\n    except Exception:\n        # Fallback: simplemente imprimimos en la consola si existe\n        print(f\"[TEOIGO] {title}: {message}\")\n\n\n# ============================================================================\n# CLASE PRINCIPAL DEL CLIENTE\n# ============================================================================\n\nclass TeoigoClient:\n    \"\"\"Cliente de dictado por voz que conecta con el backend Whisper.\"\"\"\n\n    def __init__(self):\n        self.is_recording = False\n        self.audio_data = []\n        self.stream = None\n        self._lock = threading.Lock()\n\n    def toggle_recording(self):\n        \"\"\"Alterna entre iniciar y detener la grabacion.\"\"\"\n        with self._lock:\n            if self.is_recording:\n                self._stop_and_transcribe()\n            else:\n                self._start_recording()\n\n    def _start_recording(self):\n        \"\"\"Inicia la captura de audio del microfono.\"\"\"\n        self.audio_data = []\n        self.is_recording = True\n\n        def audio_callback(indata, frames, time_info, status):\n            if status:\n                print(f\"[TEOIGO] Warning de audio: {status}\")\n            self.audio_data.append(indata.copy())\n\n        try:\n            self.stream = sd.InputStream(\n                samplerate=SAMPLE_RATE,\n                channels=CHANNELS,\n                dtype='int16',\n                callback=audio_callback,\n            )\n            self.stream.start()\n            show_toast(\n                \"TEOIGO\",\n                \"Grabando... Habla ahora.\\n\\nPresiona Ctrl+Flecha Derecha para detener.\",\n                duration_ms=10000,\n            )\n        except Exception as e:\n            self.is_recording = False\n            show_toast(\"TEOIGO\", f\"Error al acceder al microfono:\\n{e}\")\n\n    def _stop_and_transcribe(self):\n        \"\"\"Detiene la grabacion, envia el audio al servidor y pega el texto.\"\"\"\n        self.is_recording = False\n\n        # Detener el stream de audio\n        if self.stream:\n            self.stream.stop()\n            self.stream.close()\n            self.stream = None\n\n        if not self.audio_data:\n            show_toast(\"TEOIGO\", \"No se grabo audio.\")\n            return\n\n        show_toast(\n            \"TEOIGO\",\n            \"Enviando audio a Whisper...\\nEspera un momento.\",\n            duration_ms=15000,\n        )\n\n        # Concatenar todos los fragmentos de audio en un solo array\n        audio_np = np.concatenate(self.audio_data, axis=0)\n\n        # Convertir a formato WAV en memoria (sin guardar archivo)\n        wav_buffer = io.BytesIO()\n        with wave.open(wav_buffer, 'wb') as wf:\n            wf.setnchannels(CHANNELS)\n            wf.setsampwidth(2)  # 16-bit = 2 bytes\n            wf.setframerate(SAMPLE_RATE)\n            wf.writeframes(audio_np.tobytes())\n        wav_buffer.seek(0)\n\n        # Enviar al backend Whisper\n        try:\n            response = requests.post(\n                WHISPER_URL,\n                headers={\n                    \"Authorization\": f\"Bearer {API_KEY}\",\n                    \"accept\": \"application/json\",\n                },\n                files={\n                    \"audio\": (\"dictado.wav\", wav_buffer, \"audio/wav\"),\n                },\n                timeout=60,  # Maximo 60 segundos de espera\n            )\n\n            if response.status_code == 200:\n                text = response.json()\n                if text and text.strip():\n                    # Guardar el texto original del portapapeles\n                    original_clipboard = \"\"\n                    try:\n                        original_clipboard = pyperclip.paste()\n                    except Exception:\n                        pass\n\n                    # Pegar el texto transcrito donde esta el cursor\n                    pyperclip.copy(text.strip())\n                    time.sleep(0.05)  # Pequena pausa para estabilidad\n                    pyautogui.hotkey('ctrl', 'v')\n                    time.sleep(0.1)\n\n                    # Restaurar el portapapeles original\n                    try:\n                        pyperclip.copy(original_clipboard)\n                    except Exception:\n                        pass\n\n                    show_toast(\n                        \"TEOIGO\",\n                        f\"Transcrito:\\n\\\"{text.strip()[:100]}...\\\"\" if len(text.strip()) > 100\n                        else f\"Transcrito:\\n\\\"{text.strip()}\\\"\",\n                        duration_ms=3000,\n                    )\n                else:\n                    show_toast(\"TEOIGO\", \"No se detecto habla en el audio.\")\n            elif response.status_code == 401:\n                show_toast(\"TEOIGO\", \"API KEY invalida.\\nRevisa la configuracion.\")\n            else:\n                show_toast(\n                    \"TEOIGO\",\n                    f\"Error del servidor: {response.status_code}\\n{response.text[:200]}\",\n                )\n        except requests.exceptions.ConnectionError:\n            show_toast(\n                \"TEOIGO\",\n                \"No se pudo conectar a teoigo.alianed.com.\\nVerifica tu conexion a internet.\",\n            )\n        except requests.exceptions.Timeout:\n            show_toast(\n                \"TEOIGO\",\n                \"El servidor tardo demasiado en responder.\\nIntenta con un audio mas corto.\",\n            )\n        except Exception as e:\n            show_toast(\"TEOIGO\", f\"Error inesperado:\\n{e}\")\n\n\n# ============================================================================\n# PUNTO DE ENTRADA\n# ============================================================================\n\ndef main():\n    client = TeoigoClient()\n\n    print(\"=\" * 60)\n    print(\"  TEOIGO \u2014 Cliente de Dictado por Voz ALiaNeD\")\n    print(\"=\" * 60)\n    print(f\"  Servidor:  {WHISPER_URL}\")\n    print(f\"  API Key:   {'*' * (len(API_KEY) - 4)}{API_KEY[-4:]}\")\n    print()\n    print(\"  Ctrl + Flecha Derecha  \u2192  Iniciar / Detener grabacion\")\n    print(\"  Ctrl + Shift + F12    \u2192  Salir del programa\")\n    print(\"=\" * 60)\n    print()\n    print(\"  [Listo] Esperando tu voz en cualquier aplicacion...\")\n    print()\n\n    show_toast(\n        \"TEOIGO Activado\",\n        \"Ctrl + Flecha Derecha = Dictar\\nCtrl + Shift + F12 = Salir\",\n        duration_ms=4000,\n    )\n\n    # Registrar hotkeys globales\n    keyboard.add_hotkey(\n        'ctrl+right',\n        lambda: threading.Thread(target=client.toggle_recording, daemon=True).start(),\n        suppress=True,  # Evita que el atajo pase a la app activa\n    )\n\n    keyboard.add_hotkey(\n        'ctrl+shift+f12',\n        lambda: (show_toast(\"TEOIGO\", \"Cerrando...\", 1000), time.sleep(0.5), os._exit(0)),\n        suppress=True,\n    )\n\n    # Mantener el proceso vivo\n    keyboard.wait()\n\n\nif __name__ == \"__main__\":\n    main()\n